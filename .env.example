# Copy values into `.env.local` (not committed).

# Sentry DSN — in Sentry: left sidebar → Settings (gear) → Projects →
# "javascript-nextjs" → Client Keys (DSN). Same value for browser + server unless you split projects.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: server/edge only; if empty, server configs fall back to NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=

# Optional build/CI: Settings → Account → Auth Tokens (scopes: org:read, project:releases) for source maps.
# SENTRY_AUTH_TOKEN=
