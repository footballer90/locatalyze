{
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=8192",
      "HUSKY": "0"
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "locatalyze.vercel.app"
        }
      ],
      "destination": "https://locatalyze.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "locatalyze-.*\\.vercel\\.app"
        }
      ],
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}